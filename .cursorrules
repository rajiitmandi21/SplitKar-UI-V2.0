{
  "rules":[
    {
      "pattern": "**/.env*",
      "context": "block",
      "comment": "Environment variables with API keys and secrets"
    },
    {
      "pattern": "**/*.key",
      "context": "block",
      "comment": "Private keys and certificates"
    },
    {
      "pattern": "**/*.pem",
      "context": "block",
      "comment": "SSL certificates and private keys"
    },
    {
      "pattern": "**/secrets/**",
      "context": "block",
      "comment": "Secret management directories"
    },
    {
      "pattern": "**/credentials/**",
      "context": "block",
      "comment": "Authentication credentials"
    },
    {
      "pattern": "**/*.log",
      "context": "block",
      "comment": "Log files may contain sensitive data"
    },
    {
      "pattern": "app/**/*.{ts,tsx}",
      "context": "include",
      "priority": 1,
      "comment": "Next.js App Router pages and layouts - core frontend"
    },
    {
      "pattern": "components/**/*.{ts,tsx}",
      "context": "include",
      "priority": 1,
      "comment": "React components - UI building blocks"
    },
    {
      "pattern": "backend/src/**/*.{ts,js}",
      "context": "include",
      "priority": 1,
      "comment": "Backend API logic and services"
    },
    {
      "pattern": "lib/**/*.{ts,js}",
      "context": "include",
      "priority": 1,
      "comment": "Shared utilities and core business logic"
    },
    {
      "pattern": "utils/**/*.{ts,js}",
      "context": "include",
      "priority": 0.8,
      "comment": "Helper functions and utilities"
    },
    {
      "pattern": "types/**/*.{ts,d.ts}",
      "context": "include",
      "priority": 0.8,
      "comment": "TypeScript type definitions"
    },
    {
      "pattern": "hooks/**/*.{ts,tsx}",
      "context": "include",
      "priority": 0.8,
      "comment": "Custom React hooks"
    },
    {
      "pattern": "backend/src/**/*.sql",
      "context": "include",
      "priority": 0.7,
      "comment": "Database schemas and migrations"
    },
    {
      "pattern": "docs/**/*.md",
      "context": "include",
      "priority": 0.9,
      "comment": "Project documentation and guides"
    },
    {
      "pattern": "README.md",
      "context": "include",
      "priority": 1,
      "comment": "Main project documentation"
    },
    {
      "pattern": "CHANGELOG.md",
      "context": "include",
      "priority": 0.6,
      "comment": "Version history and changes"
    },
    {
      "pattern": "package.json",
      "context": "include",
      "priority": 0.9,
      "comment": "Dependencies and scripts"
    },
    {
      "pattern": "tsconfig.json",
      "context": "include",
      "priority": 0.8,
      "comment": "TypeScript configuration"
    },
    {
      "pattern": "tailwind.config.{js,ts}",
      "context": "include",
      "priority": 0.7,
      "comment": "Tailwind CSS configuration"
    },
    {
      "pattern": "next.config.{js,mjs}",
      "context": "include",
      "priority": 0.7,
      "comment": "Next.js configuration"
    },
    {
      "pattern": ".cursorrules",
      "context": "include",
      "priority": 0.5,
      "comment": "AI context rules for this project"
    },
    {
      "pattern": "**/*.test.{ts,tsx,js,jsx}",
      "context": "exclude",
      "comment": "Unit and integration tests"
    },
    {
      "pattern": "**/*.spec.{ts,tsx,js,jsx}",
      "context": "exclude",
      "comment": "Test specifications"
    },
    {
      "pattern": "**/__tests__/**",
      "context": "exclude",
      "comment": "Test directories"
    },
    {
      "pattern": "**/test/**",
      "context": "exclude",
      "comment": "Test utilities and fixtures"
    },
    {
      "pattern": "jest.config.*",
      "context": "exclude",
      "comment": "Jest testing configuration"
    },
    {
      "pattern": "cypress/**",
      "context": "exclude",
      "comment": "End-to-end test files"
    },
    {
      "pattern": "node_modules/**",
      "context": "exclude",
      "comment": "Third-party dependencies"
    },
    {
      "pattern": ".next/**",
      "context": "exclude",
      "comment": "Next.js build output"
    },
    {
      "pattern": "dist/**",
      "context": "exclude",
      "comment": "Distribution/build files"
    },
    {
      "pattern": "build/**",
      "context": "exclude",
      "comment": "Build artifacts"
    },
    {
      "pattern": "out/**",
      "context": "exclude",
      "comment": "Export output directory"
    },
    {
      "pattern": "coverage/**",
      "context": "exclude",
      "comment": "Test coverage reports"
    },
    {
      "pattern": "**/*.min.{js,css}",
      "context": "exclude",
      "comment": "Minified files"
    },
    {
      "pattern": ".cache/**",
      "context": "exclude",
      "comment": "Cache directories"
    },
    {
      "pattern": "tmp/**",
      "context": "exclude",
      "comment": "Temporary files"
    },
    {
      "pattern": "temp/**",
      "context": "exclude",
      "comment": "Temporary directories"
    },
    {
      "pattern": "logs/**",
      "context": "exclude",
      "comment": "Application logs"
    },
    {
      "pattern": "**/*.tsbuildinfo",
      "context": "exclude",
      "comment": "TypeScript build cache"
    },
    {
      "pattern": ".vscode/**",
      "context": "exclude",
      "comment": "VS Code settings"
    },
    {
      "pattern": ".idea/**",
      "context": "exclude",
      "comment": "IntelliJ IDEA settings"
    },
    {
      "pattern": ".DS_Store",
      "context": "exclude",
      "comment": "macOS system files"
    },
    {
      "pattern": "Thumbs.db",
      "context": "exclude",
      "comment": "Windows system files"
    },
    {
      "pattern": ".git/**",
      "context": "exclude",
      "comment": "Git repository data"
    },
    {
      "pattern": ".gitignore",
      "context": "exclude",
      "comment": "Git ignore rules"
    },
    {
      "pattern": "package-lock.json",
      "context": "exclude",
      "comment": "NPM lock file"
    },
    {
      "pattern": "yarn.lock",
      "context": "exclude",
      "comment": "Yarn lock file"
    },
    {
      "pattern": "pnpm-lock.yaml",
      "context": "exclude",
      "comment": "PNPM lock file"
    },
    {
      "pattern": ".*_backup\\..*$",
      "context": "exclude",
      "isRegex": true,
      "comment": "Backup files with _backup suffix (any extension)"
    },
    {
      "pattern": ".*\\.old$",
      "context": "exclude",
      "isRegex": true,
      "comment": "Old files with .old extension"
    },

    {
      "pattern": "frontend/src/**/*.{ts,tsx}",
      "context": "include",
      "priority": 1,
      "comment": "Next.js frontend application source code (from frontend/src)"
    },
    {
      "pattern": "frontend/public/**",
      "context": "include",
      "priority": 0.6,
      "comment": "Static assets for frontend"
    },
    {
      "pattern": "frontend/docs/**/*.md",
      "context": "include",
      "priority": 0.9,
      "comment": "Frontend-specific documentation"
    },
    {
      "pattern": "backend/db/**/*.sql",
      "context": "include",
      "priority": 0.7,
      "comment": "Database migrations and seeds"
    },
    {
      "pattern": "backend/docs/**/*.md",
      "context": "include",
      "priority": 0.9,
      "comment": "Backend-specific documentation"
    },
    {
      "pattern": "scripts/**/*.{js,ts,sh,py}",
      "context": "include",
      "priority": 0.7,
      "comment": "Deployment and utility scripts"
    },
    {
      "pattern": ".github/**/*.{yml,yaml}",
      "context": "include",
      "priority": 0.6,
      "comment": "GitHub workflows and templates"
    },
    {
      "pattern": ".eslintrc.{js,json,yaml,yml,cjs,mjs}",
      "context": "include",
      "priority": 0.7,
      "comment": "ESLint configuration"
    },
    {
      "pattern": "{prettier.config.{js,cjs,mjs},.prettierrc.{js,json,yaml,yml,toml}}",
      "context": "include",
      "priority": 0.7,
      "comment": "Prettier configuration"
    },
    {
      "pattern": ".husky/**",
      "context": "include",
      "priority": 0.6,
      "comment": "Husky pre-commit hooks configuration"
    },
    {
      "pattern": "LICENSE*",
      "context": "include",
      "priority": 0.5,
      "comment": "Project license information"
    }
  ],

  "context": {
    "project": "SplitKar - Expense Splitting Application",
    "version": "2.0",
    "description": "Full-stack TypeScript application for managing shared expenses with advanced splitting algorithms and real-time collaboration",

    "architecture": {
      "frontend": {
        "framework": "Next.js 14+ with App Router",
        "language": "TypeScript",
        "styling": "Tailwind CSS with shadcn/ui components",
        "state": "React hooks and context",
        "deployment": "Vercel"
      },
      "backend": {
        "framework": "Express.js with TypeScript",
        "database": "PostgreSQL with connection pooling",
        "cache": "Redis for session and data caching",
        "auth": "JWT tokens with refresh mechanism",
        "deployment": "Node.js environment"
      }
    },

    "key_features": [
      "Multi-user authentication with role-based access",
      "Group management with invitation system",
      "Advanced expense splitting (equal, percentage, custom amounts)",
      "Settlement tracking with payment confirmation",
      "Real-time notifications via email and in-app",
      "Analytics dashboard with spending insights",
      "Mobile-responsive PWA design",
      "Offline capability with sync"
    ],

    "coding_standards": {
      "typescript": {
        "mode": "strict",
        "preferences": "interfaces over types for object shapes",
        "patterns": "proper error handling with custom error classes"
      },
      "react": {
        "components": "functional components with hooks",
        "preference": "Server Components when possible",
        "patterns": "compound components for complex UI"
      },
      "api": {
        "style": "RESTful with consistent error responses",
        "auth": "JWT with proper token refresh",
        "validation": "Zod schemas for request/response validation"
      },
      "database": {
        "style": "normalized schema with proper indexing",
        "migrations": "versioned SQL migrations",
        "queries": "parameterized queries to prevent SQL injection"
      }
    },

    "file_conventions": {
      "components": "PascalCase (UserProfile.tsx)",
      "pages": "kebab-case (user-profile.tsx)",
      "utilities": "camelCase (formatCurrency.ts)",
      "types": "PascalCase (UserProfile.ts)",
      "constants": "UPPER_SNAKE_CASE (API_ENDPOINTS.ts)",
      "hooks": "camelCase with 'use' prefix (useUserData.ts)"
    },

    "security_considerations": [
      "All user inputs validated on both client and server",
      "JWT tokens stored securely with httpOnly cookies",
      "Rate limiting implemented on all API endpoints",
      "SQL injection prevention with parameterized queries",
      "XSS prevention with proper input sanitization",
      "CSRF protection with token validation"
    ],

    "performance_patterns": [
      "Database query optimization with proper indexing",
      "Redis caching for frequently accessed data",
      "Next.js image optimization for all media",
      "Code splitting for optimal bundle sizes",
      "Server-side rendering for SEO and performance",
      "Progressive Web App for offline functionality"
    ],

    "legacy_notes": {
      "v1_migration": "Legacy expense calculation logic in backend/src/legacy/ - handle with care, deprecated patterns",
      "old_auth": "Previous auth system files marked with _old suffix - reference only, do not modify"
    }
  }
}
